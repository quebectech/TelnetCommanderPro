<Window x:Class="TelnetCommanderPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Telnet Commander Pro" 
        Height="750" Width="1300"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Icon="app.ico">
    <Border CornerRadius="12" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Direction="0" ShadowDepth="0" Opacity="0.15" BlurRadius="25"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Window Control Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" Panel.ZIndex="1000">
                <!-- Minimize Button -->
                <Button Content="─" 
                        Width="36" 
                        Height="36" 
                        Click="Minimize_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#6C757D"
                        FontSize="18"
                        Cursor="Hand"
                        Margin="0,0,4,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="6"
                                                Width="36"
                                                Height="36">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-8,0,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8F9FA"/>
                                    <Setter Property="Foreground" Value="#495057"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                
                <!-- Close Button -->
                <Button Content="✕" 
                        Width="36" 
                        Height="36" 
                        Click="Close_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#6C757D"
                        FontSize="18"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="6"
                                                Width="36"
                                                Height="36">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8F9FA"/>
                                    <Setter Property="Foreground" Value="#DC3545"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            
            <!-- Top Section -->
            <Grid Grid.Row="0" Margin="24,20,24,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Title Section -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Ellipse Width="40" Height="40" Margin="0,0,12,0">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0078D4" Offset="0"/>
                                    <GradientStop Color="#00BCF2" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="⚡" FontSize="24" Foreground="White" Margin="-34,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Telnet Commander Pro" 
                                   FontSize="24" 
                                   FontWeight="SemiBold" 
                                   Foreground="#212529" 
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,100,0">
                        <Button Content="⚙ Settings" Width="120" Height="38" Click="Settings_Click" FontSize="13" Margin="0,0,10,0" Style="{StaticResource SecondaryButton}" Padding="12,0"/>
                        <Button Content="📖 Instructions" Width="140" Height="38" Click="Instructions_Click" FontSize="13" Margin="0,0,10,0" Style="{StaticResource SecondaryButton}" Padding="12,0"/>
                        <Button Content="⬆ Upgrade License" Width="160" Height="38" Click="UpgradeLicense_Click" FontSize="13" Style="{StaticResource ModernButton}" Padding="12,0"/>
                    </StackPanel>
                </Grid>
                
                <!-- License Info -->
                <Border Grid.Row="1" Background="#E7F3FF" CornerRadius="8" Padding="16" Margin="0,0,0,16" BorderBrush="#0078D4" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="🔐" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="LicenseTierText" Text="License: Advanced" FontSize="14" FontWeight="SemiBold" Foreground="#0078D4" Margin="0,0,0,4"/>
                            <TextBlock x:Name="LicenseFeaturesText" Text="✓ Routers: V5, V6 | ✓ All SSIDs (1-6)" FontSize="12" Foreground="#495057"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="VersionText" Text="v1.0.2" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="PendingSyncText" Text="" FontSize="11" Foreground="#E67E22" HorizontalAlignment="Right" Margin="0,4,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Router Model Selection and SSID Selection Combined -->
                <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="8" Padding="20" Margin="0,0,0,16" BorderBrush="#DEE2E6" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Router Selection -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Select Router Model:" FontSize="14" FontWeight="SemiBold" Foreground="#495057" Margin="0,0,0,12"/>
                            <ComboBox x:Name="RouterTypeCombo" Background="White" Foreground="#212529" BorderBrush="#CED4DA" BorderThickness="1" Height="42" Padding="12,0" FontSize="14" SelectionChanged="RouterTypeCombo_SelectionChanged" ToolTip="Select your Huawei router model">
                                <ComboBoxItem Content="Huawei V5" Tag="V5" ToolTip="Older Huawei router model with basic SSID configuration"/>
                                <ComboBoxItem Content="Huawei V6" IsSelected="True" Tag="V6" ToolTip="Standard Huawei router model with advanced WLAN settings"/>
                                <ComboBoxItem Content="Huawei X6" Tag="X6" ToolTip="Latest Huawei router model with enhanced features"/>
                            </ComboBox>
                            <TextBlock x:Name="OperationsInfo" Text="(⚡ Huawei V6 - 7 operations)" FontSize="12" Foreground="#0078D4" Margin="0,8,0,0" FontWeight="Medium"/>
                        </StackPanel>
                        
                        <!-- Vertical Separator -->
                        <Border Grid.Column="1" Width="1" Background="#DEE2E6" Margin="20,0"/>
                        
                        <!-- SSID Selection (Only for Advanced/Enterprise) -->
                        <StackPanel x:Name="SsidSelectionBorder" Grid.Column="2" Visibility="Visible">
                            <TextBlock Text="Select SSIDs to Configure:" FontSize="14" FontWeight="SemiBold" Foreground="#495057" Margin="0,0,0,12"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- 2.4GHz SSIDs -->
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="2.4GHz Network" FontSize="11" FontWeight="Medium" Foreground="#0078D4" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="Ssid1CheckBox" Content="SSID 1" FontSize="12" Margin="0,0,0,4" IsChecked="True" Checked="SsidCheckBox_Changed" Unchecked="SsidCheckBox_Changed" ToolTip="Primary 2.4GHz network"/>
                                    <CheckBox x:Name="Ssid2CheckBox" Content="SSID 2" FontSize="12" Margin="0,0,0,4" Checked="SsidCheckBox_Changed" Unchecked="SsidCheckBox_Changed" ToolTip="Secondary 2.4GHz network"/>
                                    <CheckBox x:Name="Ssid3CheckBox" Content="SSID 3" FontSize="12" Margin="0,0,0,4" Checked="SsidCheckBox_Changed" Unchecked="SsidCheckBox_Changed" ToolTip="Tertiary 2.4GHz network"/>
                                </StackPanel>
                                
                                <!-- 5GHz SSIDs -->
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="5GHz Network" FontSize="11" FontWeight="Medium" Foreground="#0078D4" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="Ssid4CheckBox" Content="SSID 4" FontSize="12" Margin="0,0,0,4" Checked="SsidCheckBox_Changed" Unchecked="SsidCheckBox_Changed" ToolTip="Primary 5GHz network"/>
                                    <CheckBox x:Name="Ssid5CheckBox" Content="SSID 5" FontSize="12" Margin="0,0,0,4" IsChecked="True" Checked="SsidCheckBox_Changed" Unchecked="SsidCheckBox_Changed" ToolTip="Secondary 5GHz network"/>
                                    <CheckBox x:Name="Ssid6CheckBox" Content="SSID 6" FontSize="12" Margin="0,0,0,4" Checked="SsidCheckBox_Changed" Unchecked="SsidCheckBox_Changed" ToolTip="Tertiary 5GHz network"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Connection Settings -->
                <Border Grid.Row="3" Background="#F8F9FA" CornerRadius="8" Padding="20" Margin="0,0,0,16" BorderBrush="#DEE2E6" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Host:" FontSize="13" Foreground="#495057" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox x:Name="HostIpInput" Grid.Column="1" Text="192.168.100.1" Background="White" Foreground="#212529" BorderBrush="#CED4DA" BorderThickness="1" Height="36" Padding="10,0" FontSize="13" VerticalContentAlignment="Center"/>
                        
                        <TextBlock Grid.Column="2" Text="Username:" FontSize="13" Foreground="#495057" VerticalAlignment="Center" Margin="20,0,12,0"/>
                        <TextBox Grid.Column="3" Text="root" Background="#E9ECEF" Foreground="#6C757D" BorderBrush="#CED4DA" BorderThickness="1" Height="36" Padding="10,0" FontSize="13" IsReadOnly="True" VerticalContentAlignment="Center"/>
                        
                        <TextBlock Grid.Column="4" Text="Password:" FontSize="13" Foreground="#495057" VerticalAlignment="Center" Margin="20,0,12,0"/>
                        <PasswordBox x:Name="PasswordInput" Grid.Column="5" Password="adminHW123" Background="White" Foreground="#212529" BorderBrush="#CED4DA" BorderThickness="1" Height="36" Padding="10,0" FontSize="13" VerticalContentAlignment="Center"/>
                        
                        <StackPanel Grid.Column="6" Orientation="Horizontal" Margin="20,0,0,0">
                            <Button x:Name="ConnectButton" Content="? Connect" Width="110" Height="36" Click="Connect_Click" Style="{StaticResource ModernButton}" FontSize="13" Margin="0,0,8,0"/>
                            <Button x:Name="DisconnectButton" Content="⊗ Disconnect" Width="110" Height="36" Click="Connect_Click" Style="{StaticResource SecondaryButton}" FontSize="13" IsEnabled="False"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Secure Operations Header -->
                <TextBlock Grid.Row="4" Text="Secure Operations" FontSize="15" FontWeight="SemiBold" Foreground="#212529" Margin="0,0,0,12"/>
            </Grid>
            
            <!-- Main Content Area -->
            <Grid Grid.Row="1" Margin="24,0,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                
                <!-- Operations List -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,0,16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="OperationsPanel" Margin="0">
                            <!-- Operations will be dynamically added here -->
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                
                <!-- Selected Action Info -->
                <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" Padding="16" Margin="0,0,0,16" BorderBrush="#DEE2E6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="● Selected Action:" FontSize="13" FontWeight="SemiBold" Foreground="#212529" Margin="0,0,0,8"/>
                        <TextBlock x:Name="SelectedActionText" Text="Select a command to see details" FontSize="12" Foreground="#6C757D" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <!-- Action Buttons and Execution Log -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0" Width="180">
                        <Button x:Name="ExecuteSelectedButton" Content="⚡ Execute Selected" Height="42" Margin="0,0,0,8" Click="ExecuteSelected_Click" Style="{StaticResource ModernButton}" FontSize="13" IsEnabled="False" ToolTip="Execute only the selected operation from the list"/>
                        <Button x:Name="ExecuteAllButton" Content="▶ Execute All" Height="42" Margin="0,0,0,8" Click="ExecuteAll_Click" Style="{StaticResource ModernButton}" FontSize="13" IsEnabled="False" ToolTip="Execute all operations for the selected router model"/>
                        <Button x:Name="ExecutionHistoryButton" Content="📋 History" Height="42" Margin="0,0,0,8" Click="ExecutionHistory_Click" Style="{StaticResource SecondaryButton}" FontSize="13" ToolTip="View execution history and past logs"/>
                        <Button x:Name="NewRouterButton" Content="➕ New Router" Height="42" Margin="0,0,0,8" Click="NewRouter_Click" Style="{StaticResource SecondaryButton}" FontSize="13" ToolTip="Configure a new router connection"/>
                        <!-- Wallet balance indicator - always visible -->
                        <Border x:Name="WalletBorder" Background="#F0F9FF" BorderBrush="#0078D4" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,4,0,4">
                            <StackPanel>
                                <TextBlock Text="💰 Wallet" FontSize="11" Foreground="#0078D4" FontWeight="SemiBold"/>
                                <TextBlock x:Name="WalletBalanceText" Text="KES 0.00" FontSize="13" FontWeight="Bold" Foreground="#1F2937" Margin="0,2,0,4"/>
                                <Button x:Name="TopUpButton" Content="+ Top Up" Height="28" Click="TopUp_Click" FontSize="11" Cursor="Hand"
                                        Foreground="White" BorderThickness="0">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#0078D4" Offset="0"/>
                                            <GradientStop Color="#00BCF2" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <!-- Execution Log -->
                    <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#DEE2E6" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" Background="#F8F9FA" Padding="12,8" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1">
                                <Grid>
                                    <TextBlock Text="Execution Log" FontSize="13" FontWeight="SemiBold" Foreground="#212529" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Clear" MinWidth="60" Height="28" Click="ClearConsole_Click" FontSize="12" Margin="0,0,8,0" Padding="12,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#DEE2E6"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#DC3545"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="BorderBrush" Value="#DC3545"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="Save" MinWidth="60" Height="28" Click="SaveLog_Click" FontSize="12" Padding="12,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                                    <Setter Property="Background" Value="#0078D4"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#005A9E"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <ScrollViewer x:Name="ConsoleScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12" Background="#FAFBFC">
                                <TextBlock x:Name="ConsoleOutput" 
                                           FontFamily="Consolas" 
                                           FontSize="11" 
                                           Foreground="#212529" 
                                           TextWrapping="Wrap"
                                           LineHeight="16"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>

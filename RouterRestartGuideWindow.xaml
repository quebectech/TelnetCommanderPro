<Window x:Class="TelnetCommanderPro.RouterRestartGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restart Required to Save Settings"
        Height="580" Width="560"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="24" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#00BCF2" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <TextBlock Text="⚠" FontSize="18" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Restart Required to Save Settings" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" Width="40" Height="40" HorizontalAlignment="Right"
                            Background="Transparent" BorderThickness="0" Foreground="White"
                            FontSize="16" Cursor="Hand" Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="0,12,0,0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#DC3545"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20,24,10">
                <StackPanel>

                    <!-- Success banner -->
                    <Border Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Router unlocked successfully!" FontSize="14" FontWeight="SemiBold" Foreground="#2E7D32" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Warning banner -->
                    <Border Background="#FFF3E0" BorderBrush="#FF9800" BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="⛔" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Do NOT unplug or press the power button!" FontSize="13" FontWeight="SemiBold" Foreground="#E65100" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="A hard power cycle will relock the router and undo all changes." FontSize="12" Foreground="#BF360C" Margin="24,0,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Steps title -->
                    <TextBlock Text="How to restart from the web interface:" FontSize="14" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,14"/>

                    <!-- Step 1 -->
                    <Border Background="#F0F9FF" BorderBrush="#0078D4" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Background="#0078D4" CornerRadius="10" Width="22" Height="22" Margin="0,0,10,0">
                                    <TextBlock Text="1" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Open your browser and go to:" FontSize="13" FontWeight="SemiBold" Foreground="#1F2937" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Background="#1F2937" CornerRadius="6" Padding="10,6" Margin="32,4,0,0">
                                <TextBlock Text="http://192.168.100.1" FontFamily="Consolas" FontSize="13" Foreground="#00BCF2" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Step 2 -->
                    <Border Background="#F0F9FF" BorderBrush="#0078D4" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#0078D4" CornerRadius="10" Width="22" Height="22" Margin="0,0,10,0">
                                <TextBlock Text="2" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#1F2937" VerticalAlignment="Center">
                                <Run Text="Log in, then on the "/>
                                <Run Text="Home page" FontWeight="Bold"/>
                                <Run Text=" click the router diagram at the top. Look for the "/>
                                <Run Text="RESET" FontWeight="Bold" Foreground="#DC3545"/>
                                <Run Text=" button on the router image."/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Step 3 -->
                    <Border Background="#F0F9FF" BorderBrush="#0078D4" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#0078D4" CornerRadius="10" Width="22" Height="22" Margin="0,0,10,0">
                                <TextBlock Text="3" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#1F2937" VerticalAlignment="Center">
                                <Run Text="Under "/>
                                <Run Text="Reset and Restore Configuration" FontWeight="Bold"/>
                                <Run Text=", click the "/>
                                <Run Text="Restart" FontWeight="Bold" Foreground="#0078D4"/>
                                <Run Text=" button (NOT Restore Defaults)."/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Step 4 -->
                    <Border Background="#F0F9FF" BorderBrush="#0078D4" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#0078D4" CornerRadius="10" Width="22" Height="22" Margin="0,0,10,0">
                                <TextBlock Text="4" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Wait for the router to restart. Settings are now permanent." FontSize="13" Foreground="#1F2937" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Next router note -->
                    <Border Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="8" Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Ready for the next router — click OK then Execute All." FontSize="12" Foreground="#495057" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="0,0,12,12" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
                <Button Content="OK - I'll restart from the web interface" Width="280" Height="40"
                        HorizontalAlignment="Right" Margin="0,0,24,0"
                        Click="Close_Click" Cursor="Hand"
                        FontSize="13" FontWeight="SemiBold">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0078D4" Offset="0"/>
                                        <GradientStop Color="#00BCF2" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>

<Window x:Class="TelnetCommanderPro.TopUpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Top Up Wallet"
        Height="520" Width="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="24" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#00BCF2" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <TextBlock Text="💰" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Top Up Wallet" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" Width="40" Height="40" HorizontalAlignment="Right"
                            Background="Transparent" BorderThickness="0" Foreground="White"
                            FontSize="16" Cursor="Hand" Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="0,12,0,0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#DC3545"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="24,20,24,10">

                <!-- Current balance -->
                <Border Background="#E7F3FF" BorderBrush="#0078D4" BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Current Balance: " FontSize="13" Foreground="#495057" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CurrentBalanceText" Text="KES 0.00" FontSize="14" FontWeight="Bold" Foreground="#0078D4" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Pricing info -->
                <Border Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Pricing per operation:" FontSize="12" FontWeight="SemiBold" Foreground="#495057" Margin="0,0,0,6"/>
                        <TextBlock Text="• V5 / V6 router  →  KES 100" FontSize="12" Foreground="#495057" Margin="0,0,0,3"/>
                        <TextBlock Text="• X6 router          →  KES 150" FontSize="12" Foreground="#495057"/>
                    </StackPanel>
                </Border>

                <!-- Phone number -->
                <TextBlock Text="M-Pesa Phone Number" FontSize="13" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,6"/>
                <Border BorderBrush="#CED4DA" BorderThickness="1" CornerRadius="6" Margin="0,0,0,16">
                    <TextBox x:Name="PhoneInput" Text="07" Height="40" Padding="12,0"
                             FontSize="13" BorderThickness="0" VerticalContentAlignment="Center"
                             Background="White"/>
                </Border>

                <!-- Amount -->
                <TextBlock Text="Amount (KES)" FontSize="13" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,6"/>
                <Border BorderBrush="#CED4DA" BorderThickness="1" CornerRadius="6" Margin="0,0,0,6">
                    <TextBox x:Name="AmountInput" Text="100" Height="40" Padding="12,0"
                             FontSize="13" BorderThickness="0" VerticalContentAlignment="Center"
                             Background="White"/>
                </Border>
                <TextBlock Text="Minimum: KES 100" FontSize="11" Foreground="#6C757D" Margin="0,0,0,16"/>

                <!-- Status -->
                <TextBlock x:Name="StatusText" Text="" FontSize="12" Foreground="#0078D4"
                           TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                           Visibility="Collapsed"/>

                <!-- Spinner -->
                <ProgressBar x:Name="Spinner" IsIndeterminate="True" Height="4"
                             Foreground="#0078D4" Background="#E5E7EB" BorderThickness="0"
                             Visibility="Collapsed" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="0,0,12,12" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button Content="Cancel" Width="90" Height="38" Margin="0,0,10,0"
                            Click="Close_Click" Cursor="Hand" FontSize="13"
                            Background="#6B7280" Foreground="White" BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="PayButton" Content="Pay via M-Pesa" Width="140" Height="38"
                            Click="Pay_Click" Cursor="Hand" FontSize="13" FontWeight="SemiBold"
                            Foreground="White" BorderThickness="0">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0078D4" Offset="0"/>
                                <GradientStop Color="#00BCF2" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

<Window x:Class="TelnetCommanderProInstaller.InstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Telnet Commander Pro Setup" 
        Height="600" Width="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    
    <Border Background="White" 
            CornerRadius="12" 
            BorderBrush="#E5E7EB" 
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="30" ShadowDepth="0"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>
            
            <!-- Header with Blue Gradient -->
            <Border Grid.Row="0" 
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#00BCF2" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0">
                        <Ellipse Width="32" Height="32" Margin="0,0,12,0">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00BCF2" Offset="0"/>
                                    <GradientStop Color="#0078D4" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="⚡" FontSize="20" VerticalAlignment="Center" 
                                   Margin="-38,0,0,0" Foreground="White"/>
                        <TextBlock Text="Telnet Commander Pro Setup" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="White" 
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </StackPanel>
                    
                    <Button Content="✕" 
                            Width="46" 
                            Height="46" 
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="20"
                            Cursor="Hand"
                            HorizontalAlignment="Right"
                            Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="0,12,0,0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#DC3545"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Content Area -->
            <Grid Grid.Row="1" x:Name="ContentArea" Margin="50,40">
                <!-- Welcome Page -->
                <StackPanel x:Name="WelcomePage" Visibility="Visible">
                    <Ellipse Width="80" Height="80" Margin="0,0,0,20" HorizontalAlignment="Center">
                        <Ellipse.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0078D4" Offset="0"/>
                                <GradientStop Color="#00BCF2" Offset="1"/>
                            </LinearGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="⚡" FontSize="48" HorizontalAlignment="Center" 
                               Margin="0,-70,0,40" Foreground="White"/>
                    
                    <TextBlock x:Name="WelcomeTitle"
                               Text="Welcome to Telnet Commander Pro" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="#1F2937" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    
                    <TextBlock x:Name="InstallerVersionText" Text="Version 2.0.5" 
                               FontSize="14" 
                               Foreground="#6B7280" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>
                    
                    <TextBlock x:Name="WelcomeDescription"
                               TextWrapping="Wrap" 
                               FontSize="14" 
                               Foreground="#4B5563" 
                               LineHeight="24"
                               TextAlignment="Center"
                               Margin="0,0,0,10">
                        <Run Text="This wizard will install "/>
                        <Run Text="Telnet Commander Pro" FontWeight="SemiBold"/>
                        <Run Text=" on your computer."/>
                    </TextBlock>
                    
                    <TextBlock x:Name="WelcomeTagline"
                               Text="⚡ Your gateway to precision router control" 
                               FontSize="13" 
                               Foreground="#6B7280" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    
                    <!-- Update Details Section (Hidden by default) -->
                    <Border x:Name="UpdateDetails"
                            Visibility="Collapsed"
                            Background="#F0F9FF"
                            BorderBrush="#0078D4"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,10,0,10"
                            Height="180">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <TextBlock x:Name="UpdateDetailsText"
                                       FontSize="12"
                                       Foreground="#1F2937"
                                       LineHeight="20"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                    
                    <TextBlock TextWrapping="Wrap" 
                               FontSize="13" 
                               Foreground="#6B7280" 
                               TextAlignment="Center"
                               Margin="0,10,0,0">
                        <Run Text="Click Install to begin, or Cancel to exit Setup."/>
                    </TextBlock>
                </StackPanel>
                
                <!-- Installing Page -->
                <StackPanel x:Name="InstallingPage" Visibility="Collapsed">
                    <TextBlock Text="Installing..." 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#1F2937" 
                               HorizontalAlignment="Center"
                               Margin="0,60,0,30"/>
                    
                    <ProgressBar x:Name="InstallProgress" 
                                 Height="8" 
                                 Margin="0,0,0,20"
                                 Foreground="#0078D4"
                                 Background="#E5E7EB"
                                 BorderThickness="0"
                                 IsIndeterminate="True"/>
                    
                    <TextBlock x:Name="StatusText"
                               Text="Copying files..." 
                               FontSize="14" 
                               Foreground="#6B7280" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
                
                <!-- Complete Page -->
                <StackPanel x:Name="CompletePage" Visibility="Collapsed">
                    <Ellipse Width="80" Height="80" Fill="#10B981" Margin="0,40,0,20" HorizontalAlignment="Center"/>
                    <TextBlock Text="✓" FontSize="48" HorizontalAlignment="Center" 
                               Margin="0,-70,0,40" Foreground="White" FontWeight="Bold"/>
                    
                    <TextBlock x:Name="CompleteTitle"
                               Text="Installation Complete!" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="#1F2937" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    
                    <TextBlock x:Name="CompleteMessage"
                               TextWrapping="Wrap" 
                               FontSize="14" 
                               Foreground="#4B5563" 
                               TextAlignment="Center"
                               Margin="0,0,0,10">
                        <Run Text="Telnet Commander Pro has been successfully installed on your computer."/>
                    </TextBlock>
                    
                    <TextBlock TextWrapping="Wrap" 
                               FontSize="13" 
                               Foreground="#6B7280" 
                               TextAlignment="Center"
                               Margin="0,0,0,30">
                        <Run Text="Click Finish to launch the application."/>
                    </TextBlock>
                    
                    <CheckBox x:Name="LaunchCheckBox"
                              Content="Launch Telnet Commander Pro"
                              IsChecked="True"
                              FontSize="14"
                              Foreground="#1F2937"
                              HorizontalAlignment="Center"
                              Margin="0,20,0,0"/>
                </StackPanel>
            </Grid>
            
            <!-- Footer with Buttons -->
            <Border Grid.Row="2" 
                    Background="#F8F9FA" 
                    CornerRadius="0,0,12,12"
                    BorderBrush="#E5E7EB"
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Margin="30,0">
                    <Button x:Name="CancelButton"
                            Content="Cancel" 
                            Width="100" 
                            Height="40" 
                            Click="Cancel_Click"
                            Style="{StaticResource ModernButton}"
                            Background="#6B7280"
                            Margin="0,0,10,0"/>
                    <Button x:Name="ActionButton"
                            Content="Install" 
                            Width="100" 
                            Height="40" 
                            Click="Action_Click"
                            Style="{StaticResource ModernButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
